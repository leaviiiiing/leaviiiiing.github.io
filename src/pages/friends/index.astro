---
import Layout from "../../layouts/Layout.astro";
import FriendLinks from "@/components/friends/FriendLinks.astro";
import themeConfig from "@/theme.config";

const friendsConfig = themeConfig.friends;
const friendLinks = friendsConfig?.links ?? [];
const pageTitle = friendsConfig?.title ?? "友链";
const pageDescription =
  friendsConfig?.description ?? "";
---

<Layout pageTitle={pageTitle}>
  <div class="wrap friend-page">
    <div class="friend-header">
      <h2>{pageTitle}</h2>
      <p>{pageDescription}</p>
    </div>
    <section class="friend-section friend-links-section">
      <h3>友链列表</h3>
      <FriendLinks links={friendLinks} />
    </section>
  </div>
</Layout>

<style>
  .friend-page {
    padding: 1.5rem 1.75rem 2.5rem;
  }

  .friend-header {
    margin-bottom: 1.5rem;
  }

  .friend-section {
    margin-top: 2rem;
  }

  .friend-header h2 {
    margin: 0 0 0.35rem;
    font-size: 1.75rem;
    color: var(--grey-7);
  }

  .friend-header p {
    margin: 0;
    color: var(--grey-6);
  }

  .friend-links-section h3 {
    margin: 0 0 0.75rem;
    color: var(--grey-7);
  }

  @media (max-width: 768px) {
    .friend-page {
      padding: 1.25rem 1rem 2rem;
    }
  }
</style>
